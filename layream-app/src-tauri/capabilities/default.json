{
  "identifier": "default",
  "description": "Default capabilities for Layream",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-download-write",
    "fs:scope-download",
    "shell:allow-open",
    "dialog:default",
    "deep-link:default",
    "log:default"
  ]
}
