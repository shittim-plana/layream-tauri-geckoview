{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Layream",
  "version": "0.3.1",
  "identifier": "com.shittimplana.layream",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Layream",
        "width": 420,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        { "host": "oauth", "pathPrefix": ["/callback"] }
      ]
    },
    "shell": {
      "open": true
    }
  }
}
